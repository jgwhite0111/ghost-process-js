  "items": {
    "rusty_key": {
      "id": "rusty_key",
      "name": "Rusty Key",
      "description": "An old iron key, stained with verdigris. The teeth are filed in an unusual pattern \u2014 military, maybe, or police. It weighs more than it should.",
      "icon": "assets/items/rusty_key.png",
      "key": true,
      "pickup_message": "You found a rusty key."
    },
    "scrap_metal": {
      "id": "scrap_metal",
      "name": "Scrap",
      "description": "A twisted hunk of alloy pulled from the android's chest cavity. The serial stamp reads K-7 / EIDOLON-A12. Worth something to the right buyer.",
      "icon": "assets/items/rusty_key.png",
      "key": false,
      "pickup_message": "You salvaged some scrap metal."
    },
    "battery": {
      "id": "battery",
      "name": "Battery",
      "description": "A lithium cell still holding a partial charge. The label is in a script you can't read \u2014 Cyrillic, maybe, or something older. Smells faintly of ozone.",
      "icon": "assets/items/battery.png",
      "key": false,
      "pickup_message": "You pocketed a battery."
    },
    "datacard": {
      "id": "datacard",
      "name": "Datacard",
      "description": "A black credit-card-sized slab with a single gold contact strip. Proprietary format. The screen is dead, but the data might not be.",
      "icon": "assets/items/datacard.png",
      "key": false,
      "pickup_message": "You lifted a datacard."
    },
    "oily_rag": {
      "id": "oily_rag",
      "name": "Oily Rag",
      "description": "A shop rag soaked in synthetic lubricant. The brand stamped on the corner is the same one stenciled on the back door of the diner.",
      "icon": "assets/items/oily_rag.png",
      "key": false,
      "pickup_message": "You picked up an oily rag."
    },
    "rusted_cog": {
      "id": "rusted_cog",
      "name": "Rusted Cog",
      "description": "A clockwork gear, roughly the size of a half-dollar. Eight teeth, brass core, magnetized on one face. It ticks faintly when warmed in the hand.",
      "icon": "assets/items/rusted_cog.png",
      "key": false,
      "pickup_message": "You found a rusted cog."
    },
    "door_key": {
      "id": "door_key",
      "name": "Door Key",
      "description": "An old key. Says B2 on the shaft.",
      "icon": "assets/items/rusty_key.png",
      "key": true,
      "pickup_message": "You fished a key out from under the grate."
    }
  },
